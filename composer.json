{
    "name": "negoziator/horizon-ui",
    "description": "A rich, Inertia-powered Horizon dashboard UI as a Laravel package",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "laravel/horizon": "^5.0",
        "inertiajs/inertia-laravel": "^1.0|^2.0|^3.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "larastan/larastan": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "Negoziator\\HorizonUi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Negoziator\\HorizonUi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Negoziator\\HorizonUi\\HorizonUiServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
